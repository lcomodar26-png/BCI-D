{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Store user account details and balance.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "balance": { "type": "number" },
        "blocked": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role", "balance", "blocked"]
    },
    "Transaction": {
      "title": "Transaction Record",
      "description": "Logs of deposits and investments.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "invest", "withdraw"] },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Profiles for all users."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Universal transaction log."
    },
    "/admins/{adminId}": {
      "schema": { "type": "object", "properties": { "email": { "type": "string" } } },
      "description": "System administrators."
    }
  }
}
